<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.qihangerp.mapper.ErpWarehouseGoodsStockBatchMapper">

    <resultMap id="BaseResultMap" type="cn.qihangerp.model.entity.ErpWarehouseGoodsStockBatch">
            <id property="id" column="id" jdbcType="BIGINT"/>
            <result property="inventoryId" column="inventory_id" jdbcType="BIGINT"/>
            <result property="vendorId" column="vendor_id" jdbcType="BIGINT"/>
            <result property="batchNum" column="batch_num" jdbcType="VARCHAR"/>
            <result property="originQty" column="origin_qty" jdbcType="BIGINT"/>
            <result property="currentQty" column="current_qty" jdbcType="BIGINT"/>
            <result property="remark" column="remark" jdbcType="VARCHAR"/>
            <result property="goodsId" column="goods_id" jdbcType="BIGINT"/>
            <result property="goodsNo" column="goods_no" jdbcType="VARCHAR"/>
        <result property="purPrice" column="pur_price" jdbcType="DOUBLE"/>
        <result property="purId" column="pur_id" jdbcType="BIGINT"/>
        <result property="purItemId" column="pur_item_id" jdbcType="BIGINT"/>
        <result property="merchantId" column="merchant_id" jdbcType="BIGINT"/>
        <result property="shopId" column="shop_id" jdbcType="BIGINT"/>
        <result property="inventoryMode" column="inventory_mode" jdbcType="INTEGER"/>
        <result property="barcode" column="barcode" jdbcType="VARCHAR"/>
        <result property="actualGoldWeight" column="actual_gold_weight" jdbcType="FLOAT"/>
        <result property="actualSilverWeight" column="actual_silver_weight" jdbcType="FLOAT"/>
        <result property="laborCost" column="labor_cost" jdbcType="FLOAT"/>
        <result property="certificateNo" column="certificate_no" jdbcType="VARCHAR"/>

            <result property="warehouseId" column="warehouse_id" jdbcType="BIGINT"/>
            <result property="positionId" column="position_id" jdbcType="BIGINT"/>
            <result property="positionNum" column="position_num" jdbcType="VARCHAR"/>
            <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
            <result property="createBy" column="create_by" jdbcType="VARCHAR"/>
            <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
            <result property="updateBy" column="update_by" jdbcType="VARCHAR"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,inventory_id,batch_num,vendor_id,merchant_id,shop_id,
        origin_qty,current_qty,remark,inventory_mode,
        goods_id,goods_no,pur_price,pur_id,pur_item_id,
        warehouse_id,position_id,position_num,barcode,certificate_no,actual_gold_weight,actual_silver_weight,labor_cost,
        create_time,create_by,update_time,
        update_by
    </sql>

    <select id="searchSkuInventoryBatch" parameterType="String" resultType="cn.qihangerp.model.vo.GoodsSkuInventoryVo">
        SELECT inv.id as batchId,inv.batch_num,inv.current_qty,inv.sku_id,inv.goods_id,inv.sku_code,inv.warehouse_id,
        inv.position_id ,inv.position_num,inv.pur_price,
        spec.`sku_name`,spec.color_value,spec.color_image,spec.size_value,spec.style_value,spec.goods_name
        ,ww.`name` as warehouse_name
        FROM erp_vendor_inventory_batch as inv
        left JOIN `o_goods_sku` as spec on inv.sku_id=spec.id
        LEFT JOIN erp_vendor_warehouse as ww on ww.id = inv.warehouse_id
        <where>
            and inv.current_qty &gt; 0
            <if test="keyword != null  and keyword != ''">
                and inv.sku_code like concat('%', #{keyword}, '%')
            </if>
        </where>
    </select>
</mapper>
