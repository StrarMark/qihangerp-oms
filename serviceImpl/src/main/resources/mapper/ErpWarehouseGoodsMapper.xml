<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.qihangerp.mapper.ErpWarehouseGoodsMapper">

    <resultMap id="BaseResultMap" type="cn.qihangerp.model.entity.ErpWarehouseGoods">
            <id property="id" column="id" jdbcType="BIGINT"/>
            <result property="erpGoodsNo" column="erp_goods_no" jdbcType="VARCHAR"/>
            <result property="erpGoodsSign" column="erp_goods_sign" jdbcType="VARCHAR"/>
            <result property="goodsNo" column="goods_no" jdbcType="VARCHAR"/>
            <result property="goodsName" column="goods_name" jdbcType="VARCHAR"/>
            <result property="salesPlatformGoodsNo" column="sales_platform_goods_no" jdbcType="VARCHAR"/>
            <result property="abbreviation" column="abbreviation" jdbcType="VARCHAR"/>
            <result property="barCode" column="bar_code" jdbcType="VARCHAR"/>
            <result property="imageUrl" column="image_url" jdbcType="VARCHAR"/>
            <result property="length" column="length" jdbcType="DOUBLE"/>
            <result property="width" column="width" jdbcType="DOUBLE"/>
            <result property="height" column="height" jdbcType="DOUBLE"/>
            <result property="volume" column="volume" jdbcType="DOUBLE"/>
            <result property="grossWeight" column="gross_weight" jdbcType="DOUBLE"/>
            <result property="netWeight" column="net_weight" jdbcType="DOUBLE"/>
            <result property="color" column="color" jdbcType="VARCHAR"/>
            <result property="size" column="size" jdbcType="VARCHAR"/>
            <result property="standard" column="standard" jdbcType="VARCHAR"/>
            <result property="brandNo" column="brand_no" jdbcType="VARCHAR"/>
            <result property="brandName" column="brand_name" jdbcType="VARCHAR"/>
            <result property="erpGoodsId" column="erp_goods_id" jdbcType="BIGINT"/>
            <result property="erpGoodsSkuId" column="erp_goods_sku_id" jdbcType="BIGINT"/>
            <result property="createBy" column="create_by" jdbcType="VARCHAR"/>
            <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
            <result property="updateBy" column="update_by" jdbcType="VARCHAR"/>
            <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
            <result property="merchantId" column="merchant_id" jdbcType="BIGINT"/>
            <result property="shopId" column="shop_id" jdbcType="BIGINT"/>
            <result property="shopNo" column="shop_no" jdbcType="VARCHAR"/>
            <result property="shopName" column="shop_name" jdbcType="VARCHAR"/>
            <result property="ownerNo" column="owner_no" jdbcType="VARCHAR"/>
            <result property="warehouseNo" column="warehouse_no" jdbcType="VARCHAR"/>
            <result property="warehouseType" column="warehouse_type" jdbcType="VARCHAR"/>
            <result property="warehouseId" column="warehouse_id" jdbcType="BIGINT"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,erp_goods_no,erp_goods_sign,
        goods_no,goods_name,sales_platform_goods_no,
        abbreviation,bar_code,image_url,
        length,width,height,
        volume,gross_weight,net_weight,
        color,size,standard,
        brand_no,brand_name,erp_goods_id,
        erp_goods_sku_id,create_by,create_time,
        update_by,update_time,merchant_id,shop_id,warehouse_type,
        shop_no,shop_name,owner_no,warehouse_no,warehouse_id
    </sql>

    <select id="getVendorGoodsByCode" resultMap="BaseResultMap">
        SELECT *
        FROM `erp_warehouse_goods`

        <where>
            and warehouse_id= #{warehouseId}
            <if test="merchantId != null  and merchantId != ''">
            and merchant_id= #{merchantId}
            </if>
            <if test="code != null  and code != ''">
                and (goods_no like concat('%', #{code}, '%')
                        OR erp_goods_no like concat('%', #{code}, '%')
                        OR erp_goods_sign like concat('%', #{code}, '%')
                        OR goods_name like concat('%', #{code}, '%')
                        OR id = #{code}
                )
            </if>
        </where>
    </select>
    <select id="getVendorGoodsStockByCode" resultMap="BaseResultMap">
        SELECT *,
        (SELECT IFNULL(SUM(usable_num),0) FROM erp_warehouse_goods_stock WHERE erp_warehouse_goods_stock.goods_id=erp_warehouse_goods.id) as stock

        FROM `erp_warehouse_goods`

        <where>
            and warehouse_id= #{warehouseId}
            <if test="merchantId != null  and merchantId != ''">
                and merchant_id= #{merchantId}
            </if>
            <if test="code != null  and code != ''">
                and (goods_no like concat('%', #{code}, '%')
                OR erp_goods_no like concat('%', #{code}, '%')
                OR erp_goods_sign like concat('%', #{code}, '%')
                OR goods_name like concat('%', #{code}, '%')
                OR id = #{code}
                )
            </if>
        </where>
    </select>

</mapper>
